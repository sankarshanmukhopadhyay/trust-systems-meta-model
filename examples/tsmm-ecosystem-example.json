    {"id": "reg.primary", "type": "TrustRegistry", "label": "Primary Trust Registry"},
    {"id": "svc.reference", "type": "RegistryService", "label": "Reference Registry Service"},
    {"id": "issuer.member", "type": "Issuer", "label": "Member Issuer"},
    {"id": "subject.alice", "type": "Subject", "label": "Credential Subject"},
    {"id": "cred.membership", "type": "Credential", "label": "Membership Credential"},
    {"id": "verifier.portal", "type": "Verifier", "label": "Verifier Portal"},
    {"id": "policy.reliance", "type": "Policy", "label": "Reliance Policy"},
    {"id": "profile.al2", "type": "AssuranceProfile", "label": "AL2 Assurance Profile"},
    {"id": "evidence.bundle", "type": "EvidenceBundle", "label": "Evidence Bundle"},
    {"id": "assessment.profile", "type": "Assessment", "label": "Profile Assessment"},
    {"id": "decision.access", "type": "TrustDecision", "label": "Access Decision"},
    {"id": "effect.allow", "type": "Effect", "label": "Allow Service Access"}
