{
  "graphId": "graph.tsmm-reference-ecosystem",
  "label": "TSMM Reference Ecosystem",
  "description": "Reference graph showing the core governance and trust relationships across a registry-mediated verifiable credential ecosystem.",
  "profile": "operational",
  "contexts": [
    "cross-domain trust governance",
    "verifiable credential reliance"
