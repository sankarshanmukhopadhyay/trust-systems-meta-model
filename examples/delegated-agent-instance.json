{
  "governanceContexts": [
    {
      "id": "context.enterprise-delegation",
      "name": "Enterprise delegated-action governance",
      "description": "Organizational context for bounded delegation and review."
    }
  ],
  "profiles": [
    {
      "id": "profile.agent-delegation",
      "name": "Delegated agent action profile",
      "contextRef": "context.enterprise-delegation",
      "requirementRefs": [
        "req.no-state-mutation",
        "req.review-logging"
      ]
    }
  ],
  "requirements": [
    {
      "id": "req.no-state-mutation",
      "statement": "delegated agent may not submit purchase orders",
      "level": "baseline"
    },
    {
      "id": "req.review-logging",
      "statement": "all delegated actions must be logged for review",
      "level": "baseline"
    }
  ],
  "entities": [
    {
      "id": "entity.agent",
      "type": "software-agent",
      "name": "Delegated Procurement Agent",
      "roles": [
        {
          "id": "role.delegate",
          "type": "delegate",
          "authorities": [
            {
              "id": "auth.retrieve-quotes",
              "scope": "retrieve quotes and assemble recommendations only",
              "source": "delegation artifact signed by principal",
              "conditions": [
                "no state mutation allowed",
                "all actions must be logged for review"
              ],
              "revocationStatus": "active",
              "timeBounds": "bounded-by-policy",
              "obligations": [
                "no state mutation allowed",
                "all actions must be logged for review"
              ]
            }
          ]
        }
      ]
    }
  ],
  "artifacts": [
    {
      "id": "artifact.delegation",
      "type": "delegation-artifact",
      "claims": [
        {
          "id": "claim.agent-scope",
          "statement": "agent may retrieve quotes but may not submit purchase orders"
        }
      ]
    }
  ],
  "policies": [
    {
      "id": "policy.delegated-action",
      "name": "Delegated action policy",
      "decisionMode": "mixed",
      "profileRef": "profile.agent-delegation",
      "rules": [
        "deny actions that exceed delegated authority scope",
        "route ambiguous cases to human review"
      ],
      "contextRef": "context.enterprise-delegation"
    }
  ],
  "evidence": [
    {
      "id": "evidence.audit-log",
      "type": "audit-log",
      "supportsRefs": [
        "req.review-logging",
        "claim.agent-scope"
      ]
    }
  ],
  "assessments": [
    {
      "id": "assessment.scope-review",
      "method": "delegation-profile review",
      "result": "fail",
      "requirementRefs": [
        "req.no-state-mutation",
        "req.review-logging"
      ],
      "evidenceRefs": [
        "evidence.audit-log"
      ]
    }
  ],
  "verifications": [
    {
      "id": "verification.scope-check",
      "method": "delegation-scope-evaluation",
      "result": "fail",
      "inputRefs": [
        "artifact.delegation",
        "evidence.audit-log"
      ]
    }
  ],
  "trustDecisions": [
    {
      "id": "decision.block-state-change",
      "outcome": "deny",
      "policyRef": "policy.delegated-action",
      "assessmentRefs": [
        "assessment.scope-review"
      ],
      "verificationRefs": [
        "verification.scope-check"
      ],
      "effectRefs": [
        "effect.block-purchase-order"
      ],
      "contextRef": "context.enterprise-delegation",
      "authorityRefs": [
        "auth.retrieve-quotes"
      ]
    }
  ],
  "effects": [
    {
      "id": "effect.block-purchase-order",
      "class": "transactional",
      "action": "block attempted purchase-order submission",
      "status": "blocked"
    }
  ],
  "lifecycleEvents": [
    {
      "id": "event.delegation-revocation",
      "type": "revocation",
      "targetRef": "auth.retrieve-quotes"
    }
  ]
}
