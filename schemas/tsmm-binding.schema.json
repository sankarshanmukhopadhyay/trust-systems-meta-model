{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/tsmm/schemas/tsmm-binding.schema.json",
  "title": "TSMM Ecosystem Binding v0.10.0",
  "description": "Machine-readable mapping from an external ecosystem vocabulary into TSMM abstractions.",
  "type": "object",
  "required": ["bindingId", "label", "targetEcosystem", "mappings"],
  "properties": {
    "bindingId": {"$ref": "#/defs/idString"},
    "label": {"type": "string"},
    "description": {"type": "string"},
    "targetEcosystem": {"type": "string"},
    "version": {"type": "string"},
    "sources": {"type": "array", "items": {"type": "string"}},
    "mappings": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/defs/mapping"}
    },
    "notes": {"type": "array", "items": {"type": "string"}},
    "metadata": {
      "type": "object",
      "additionalProperties": {"type": ["string", "number", "boolean"]}
    }
  },
  "defs": {
    "idString": {"type": "string", "pattern": "^[A-Za-z0-9._:-]+$"},
    "tsmmType": {
      "type": "string",
      "enum": [
        "TrustDomain",
        "GovernanceAuthority",
        "TrustRegistry",
        "RegistryService",
        "Issuer",
        "Verifier",
        "Subject",
        "Agent",
        "Credential",
        "Policy",
        "AssuranceProfile",
        "EvidenceBundle",
        "Assessment",
        "TrustDecision",
        "Effect",
        "RelyingParty"
      ]
    },
    "mapping": {
      "type": "object",
      "required": ["externalConcept", "tsmmType", "bindingStrength"],
      "properties": {
        "externalConcept": {"type": "string"},
        "tsmmType": {"$ref": "#/defs/tsmmType"},
        "bindingStrength": {"type": "string", "enum": ["exact", "approximate", "composite"]},
        "description": {"type": "string"},
        "conditions": {"type": "array", "items": {"type": "string"}},
        "relatedDocs": {"type": "array", "items": {"type": "string"}}
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
